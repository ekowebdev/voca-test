{
    "swagger": "2.0",
    "info": {
        "description": "This is a simplified multi-currency E-Wallet backend system implemented in Go using the Repository pattern, Gin framework, and PostgreSQL.",
        "title": "Multi-Currency E-Wallet API",
        "contact": {
            "name": "API Support",
            "url": "https://github.com/voca-test"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/users": {
            "post": {
                "description": "Register a new user in the system with the provided name.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Users"
                ],
                "summary": "Create a new user",
                "parameters": [
                    {
                        "description": "User registration details",
                        "name": "user",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_models.UserCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "User created successfully",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/voca-test_internal_models.User"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid request body or validation error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets": {
            "post": {
                "description": "Register a new wallet for a specific user with a chosen currency.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Create a wallet for a user",
                "parameters": [
                    {
                        "description": "Wallet creation details",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_models.WalletCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Wallet created successfully",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/voca-test_internal_models.Wallet"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid request body or validation error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/transfer": {
            "post": {
                "description": "Transfer funds from one wallet to another. Both wallets must use the same currency. Requires an idempotency key.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Move money between same-currency wallets",
                "parameters": [
                    {
                        "description": "Transfer details",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_models.TransferRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transfer successful",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request, currency mismatch, or insufficient balance",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/{id}": {
            "get": {
                "description": "Retrieve the current balance and status of a specific wallet.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Get wallet details",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Wallet UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Wallet retrieved successfully",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/voca-test_internal_models.Wallet"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid wallet ID",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "404": {
                        "description": "Wallet not found",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/{id}/pay": {
            "post": {
                "description": "Deduct funds from a wallet for a payment. Requires an idempotency key.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Spend money from a wallet",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Wallet UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Payment details",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_models.PaymentRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payment successful",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/voca-test_internal_models.Wallet"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid request body, insufficient balance, or wallet ID",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/{id}/suspend": {
            "post": {
                "description": "Change a wallet status to SUSPENDED. Suspended wallets cannot perform transactions.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Suspend a wallet",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Wallet UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Wallet suspended successfully",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid wallet ID",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/{id}/topup": {
            "post": {
                "description": "Add funds to a wallet. Requires an idempotency key to prevent duplicate transactions.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Top-up money to a wallet",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Wallet UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Top-up details",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_models.TopUpRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Top-up successful",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/voca-test_internal_models.Wallet"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid request body or wallet ID",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        },
        "/wallets/{id}/transactions": {
            "get": {
                "description": "Retrieve a list of all transactions (ledger entries) for a specific wallet, sorted by date.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Wallets"
                ],
                "summary": "Get wallet transaction history",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Wallet UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction history retrieved successfully",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/voca-test_internal_models.LedgerEntry"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Invalid wallet ID",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/voca-test_internal_util.APIResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "voca-test_internal_models.LedgerEntry": {
            "type": "object",
            "properties": {
                "amount": {
                    "type": "number"
                },
                "balance_after": {
                    "type": "number"
                },
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "reference_id": {
                    "type": "string"
                },
                "type": {
                    "description": "TOPUP, PAYMENT, TRANSFER_IN, TRANSFER_OUT",
                    "type": "string"
                },
                "wallet_id": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.PaymentRequest": {
            "type": "object",
            "required": [
                "amount",
                "idempotency_key"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "idempotency_key": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.TopUpRequest": {
            "type": "object",
            "required": [
                "amount",
                "idempotency_key"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "idempotency_key": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.TransferRequest": {
            "type": "object",
            "required": [
                "amount",
                "from_wallet_id",
                "idempotency_key",
                "to_wallet_id"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "from_wallet_id": {
                    "type": "string"
                },
                "idempotency_key": {
                    "type": "string"
                },
                "to_wallet_id": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.User": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.UserCreateRequest": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.Wallet": {
            "type": "object",
            "required": [
                "currency"
            ],
            "properties": {
                "balance": {
                    "type": "number"
                },
                "created_at": {
                    "type": "string"
                },
                "currency": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "status": {
                    "description": "ACTIVE, SUSPENDED",
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_models.WalletCreateRequest": {
            "type": "object",
            "required": [
                "currency",
                "user_id"
            ],
            "properties": {
                "currency": {
                    "type": "string"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "voca-test_internal_util.APIResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "description": "Actual payload for success"
                },
                "errors": {
                    "description": "Specific error details (e.g., validation)"
                },
                "message": {
                    "description": "General message",
                    "type": "string"
                },
                "status": {
                    "description": "\"success\" or \"error\"",
                    "type": "string"
                }
            }
        }
    }
}